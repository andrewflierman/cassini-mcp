# LibreChat environment configuration — copy to .env and fill in real values.
# Run: cp .env.example .env

# ─── AI Provider ──────────────────────────────────────────────────────────────

# Anthropic API key for Claude models (required)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ─── Database ─────────────────────────────────────────────────────────────────

# MongoDB connection string — points to the 'mongodb' Docker Compose service
MONGO_URI=mongodb://mongodb:27017/LibreChat

# ─── Search ───────────────────────────────────────────────────────────────────

# MeiliSearch connection — points to the 'meilisearch' Docker Compose service
MEILI_HOST=http://meilisearch:7700

# MeiliSearch master key — must be at least 16 characters; set to the same
# value in both LibreChat and the meilisearch service (or its MEILI_MASTER_KEY env var).
MEILI_MASTER_KEY=change-me-to-a-random-string-of-16-or-more-characters

# ─── Secrets ──────────────────────────────────────────────────────────────────

# JWT signing keys — generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string

# Credentials encryption — used by LibreChat to encrypt stored API keys.
# CREDS_KEY: 32-byte hex string (64 hex chars).  Generate: openssl rand -hex 32
# CREDS_IV:  16-byte hex string (32 hex chars).  Generate: openssl rand -hex 16
CREDS_KEY=change-me-to-a-64-character-hex-string-for-aes256-encryption-key
CREDS_IV=change-me-to-a-32-character-hex-iv
